#!/usr/bin/env zsh

# --------------------------
# Phil McMinn's Git commands
# --------------------------

# -----------
# Git aliases
# -----------

def_alias gpl "git pull"                 "Git: alias for 'git pull'"
def_alias gsc "git-subdirectories-check" "Git: check status of repos in subdirectories"
def_alias gsp "git-subdirectories-pull"  "Git: pull all repos in subdirectories"
def_alias gst "git status"               "Git: alias for 'git status"
def_alias gwc "gw commits"               "Git: view commits on web fo repository"


# ------------
# Git commands
# ------------

add_command "gcl" "Git: clone repository and submodules"
function gcl {
  # clone repository
  git clone $1

  # change directory to repository
  basename=$(basename $1)
  dir=${basename%.*}
  cd $dir

  # also ensure submodules are cloned 
  git submodule init

  # git submodule update
  # ensure latest versions of submodules are pulled
  # which is the default behaviour I usually need.
  git submodule update --init --recursive --remote
  
  # uncomment when working again
  git-track
}

add_command "gcp" "Git: commit (with helper) then push"
function gcp {
  # check that commits need to be made
  changes=$(git diff --name-only HEAD)
  untracked=$(git ls-files --others --exclude-standard)
  if [[ -z "$changes" && -z "$untracked" ]]; then
    printf "\033[32mNothing to commit.\n\033[0m"
    return 0
  fi

  # report what needs to be committed
  printf "\n\033[1;32mTo be committed:\n\033[0m"
  echo "$changes" | while read f; do echo "  - $f"; done
  printf "\n"

  # commit using git-commit-helper
  git-commit-helper "$@" || return 1

  # push the results
  printf "\n\033[1;32mPushing...\n\033[0m"
  git push || return 1
}

add_command "gpcp" "Git: pull then gcp"
function gpcp {
  printf "\033[1;32mPulling...\n\033[0m"
  gpl || return 1

  gcp $1
}

add_command "gpl" "Git: pull including submodules"
function gpl {
  git pull
  git submodule update --init --recursive --remote
}

add_command "gw" "Git: view repository on the web"
function gw {
  url=$(git config --get remote.origin.url | sed 's|git@\(.*\):\(.*\)\.git|https://\1/\2|')
  [[ -n $1 ]] && url+="/$1"
  o "$url"
}

